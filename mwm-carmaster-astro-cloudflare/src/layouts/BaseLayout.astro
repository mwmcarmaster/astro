---
import Header from '../components/Header.astro';
import Subnav from '../components/Subnav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath = Astro.url.pathname } = Astro.props;
const canonical = Astro.site ? new URL(currentPath === '/index.html' ? '/' : currentPath, Astro.site) : undefined;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical.href} />}
    <link rel="stylesheet" href="/css/style.css" />
    <script is:inline>
      window.SITE_ANALYTICS = { provider: 'ga4', measurementId: 'G-8YZHCE24H1' };
    </script>
    <style is:global>
      .site-nav a[aria-current="page"],
      .subnav a[aria-current="page"] {
        text-decoration: underline;
        text-underline-offset: 0.22em;
      }
    </style>
  </head>
  <body>
    <Header currentPath={currentPath} />
    <Subnav currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script src="/js/main.js"></script>
    <script src="/js/analytics.js"></script>
    <script src="/js/cookies.js"></script>
  </body>
</html>
