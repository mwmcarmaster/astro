---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Cennik usług serwisowych w Kielcach";
const description = "Ceny najczęściej wykonywanych usług oraz zasady wyceny prac serwisowych.";
const currentPath = "/cennik.html";
const pageHtml = "<section class=\"hero compact\">\n<div class=\"hero-media\"><img alt=\"Cennik usług serwisowych w Kielcach\" src=\"img/services/hamulce-mechanika-serwis-mwm.jpg\"/></div>\n<div class=\"hero-overlay\"></div>\n<div class=\"container hero-inner\">\n<h1>Cennik usług serwisowych w Kielcach</h1>\n<p class=\"lead\">Prezentujemy ceny najczęściej wykonywanych usług oraz zasady wyceny prac serwisowych. Ze względu na dużą liczbę typów samochodów, wersji silnikowych i rodzajów napraw nie publikujemy pełnego cennika dla wszystkich pojazdów.</p>\n</div>\n</section>\n<section class=\"section\"><div class=\"container copy-block\"><h2>Jak ustalamy koszt usługi</h2><p>Pracujemy na katalogach czasochłonności usług przygotowanych przez producentów pojazdów. Dzięki temu możemy lepiej dopasować wycenę do konkretnego modelu samochodu, wersji silnikowej i rzeczywistego zakresu prac. Nasza stawka wynosi 200 zł brutto za roboczogodzinę.</p></div></section>\n<section class=\"section section-alt\">\n<div class=\"container copy-block\">\n<h2>Najczęściej wykonywane czynności</h2>\n<ul class=\"price-list\">\n<li><span>Wymiana zestawu rozrządu</span><strong>od 500 zł</strong></li>\n<li><span>Wymiana filtra oleju i oleju</span><strong>od 100 zł</strong></li>\n<li><span>Wymiana filtra powietrza</span><strong>od 40 zł</strong></li>\n<li><span>Wymiana kompletu świec zapłonowych</span><strong>od 60 zł</strong></li>\n<li><span>Wymiana filtra kabinowego</span><strong>od 20 zł</strong></li>\n<li><span>Wymiana cieczy chłodzącej</span><strong>od 100 zł</strong></li>\n<li><span>Wymiana płynu hamulcowego</span><strong>od 100 zł</strong></li>\n<li><span>Wymiana klocków hamulcowych</span><strong>od 150 zł za oś</strong></li>\n<li><span>Wymiana tarcz hamulcowych</span><strong>od 200 zł za oś</strong></li>\n</ul>\n</div>\n</section>\n<section class=\"section\"><div class=\"container copy-block\"><h2>Serwis klimatyzacji</h2><p>Podstawowy serwis klimatyzacji kosztuje 150 zł plus koszt czynnika chłodniczego. W ramach usługi wykonujemy odessanie czynnika z układu, kontrolę szczelności urządzeniem serwisowym, ponowne napełnienie układu zgodnie z wymaganiami producenta, uzupełnienie oleju oraz ozonowanie wnętrza pojazdu.</p><p>Czynnik R134a — 30 zł / 100 g.</p><p>Czynnik R1234yf — 100 zł / 100 g.</p></div></section><section class=\"section section-alt\"><div class=\"container copy-block\"><h2>Diagnostyka</h2><p>Diagnostyka komputerowa podstawowa / odczyt błędów — 100 zł.</p><p>Diagnostyka rozszerzona z analizą parametrów i weryfikacją działania układów — 200 zł.</p><p>Dalsza diagnostyka usterek mechanicznych, elektrycznych lub elektronicznych — 200 zł / rbh.</p></div></section><section class=\"section\"><div class=\"container copy-block\"><h2>Blokady alkoholowe Autowatch</h2><p>Opłaty do Autowatch:</p><p>Dzierżawa blokady alkoholowej — 110,70 zł miesięcznie.</p><p>Kalibracja urządzenia — 307,50 zł. Kalibracja jest wymagana co 12 miesięcy.</p><p>Opłaty w serwisie:</p><p>Montaż blokady alkoholowej — 700 zł.</p><p>Demontaż blokady alkoholowej — 307,50 zł.</p><p>Dodatkowe badanie techniczne po montażu — 76 zł.</p></div></section><section class=\"section section-dark\"><div class=\"container contact-band\"><div><h2>Skontaktuj się z nami</h2><p>Zapytaj o cenę, umów wizytę albo skontaktuj się z serwisem.</p></div>\n<div class=\"contact-list\">\n<div><strong>Bosch Car Service<br/>MWM Carmaster</strong></div>\n<div>ul. Krakowska 161, 25-705 Kielce</div>\n<div><a href=\"tel:+48605101100\">+48 605 101 100</a></div>\n<div><a href=\"tel:+48413452435\">+48 41 345 24 35</a></div>\n<div><a class=\"js-email\" data-domain=\"bosch-service.pl\" data-mail-link=\"true\" data-user=\"carmaster\" href=\"#\">carmaster [at] bosch-service.pl</a></div>\n<div>Poniedziałek–Piątek: 8:00–17:00</div>\n</div>\n</div></section>";
---
<BaseLayout title={title} description={description} currentPath={currentPath}>
  <Fragment set:html={pageHtml} />
</BaseLayout>
