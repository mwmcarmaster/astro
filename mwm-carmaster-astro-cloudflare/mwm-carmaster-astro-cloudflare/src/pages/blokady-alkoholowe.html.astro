---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Blokady alkoholowe Autowatch w Kielcach";
const description = "Montaż blokad alkoholowych Autowatch w Kielcach.";
const currentPath = "/blokady-alkoholowe.html";
const pageHtml = "<section class=\"hero compact\">\n<div class=\"hero-media\"><img alt=\"Blokady alkoholowe Autowatch w Kielcach\" src=\"img/home/obsluga-klienta-recepcja-mwm-bosch.jpg\"/></div>\n<div class=\"hero-overlay\"></div>\n<div class=\"container hero-inner\">\n<h1>Blokady alkoholowe Autowatch w Kielcach</h1>\n<p class=\"lead\">W MWM Carmaster montujemy blokady alkoholowe Autowatch. To rozwiązanie dla osób odzyskujących prawo jazdy po wyroku za jazdę w stanie nietrzeźwości, ale także dla rodziców dbających o bezpieczeństwo dzieci oraz pracodawców udostępniających samochody służbowe.</p>\n</div>\n</section>\n<section class=\"section\"><div class=\"container copy-block\"><h2>Jak działa blokada alkoholowa</h2><p>Blokada alkoholowa uniemożliwia uruchomienie pojazdu bez wcześniejszego badania trzeźwości. Jeżeli wynik jest prawidłowy, samochód można uruchomić. Jeżeli wynik jest nieprawidłowy, rozruch zostaje zablokowany.</p></div></section><section class=\"section section-alt\"><div class=\"container copy-block\"><h2>Dla kogo jest to rozwiązanie</h2><p>Blokady alkoholowe są najczęściej wybierane przez osoby, które chcą odzyskać możliwość prowadzenia samochodu po wyroku za jazdę w stanie nietrzeźwości. Mogą być również dobrym rozwiązaniem dla rodziców, którzy chcą zwiększyć bezpieczeństwo użytkowania auta przez młodych kierowców, oraz dla firm, które udostępniają samochody pracownikom.</p></div></section><section class=\"section\"><div class=\"container copy-block\"><h2>Jak wyglądają formalności</h2><p>Po odbyciu wymaganej części zakazu można złożyć do sądu wniosek o zmianę sposobu wykonywania zakazu tak, aby możliwe było prowadzenie wyłącznie pojazdu wyposażonego w blokadę alkoholową. Po spełnieniu wszystkich wymagań formalnych można przystąpić do procedury zawarcia umowy dzierżawy urządzenia i ustalenia terminu montażu.</p></div></section><section class=\"section section-alt\"><div class=\"container copy-block\"><h2>Jak wygląda obsługa w MWM Carmaster</h2><p>Jesteśmy dealerem marki Autowatch, lidera rynku blokad alkoholowych. Urządzenia są dzierżawione bezpośrednio z firmy Autowatch, a w MWM Carmaster wykonujemy montaż, przeprowadzamy wymagane czynności techniczne oraz pomagamy w formalnościach związanych z uruchomieniem usługi i dopuszczeniem pojazdu do użytkowania z blokadą alkoholową. Montaż trwa od około 4 godzin i jest możliwy wyłącznie w siedzibie firmy.</p><p>Najpierw wypełniasz formularz dzierżawy w Autowatch i jako dealera wskazujesz MWM Carmaster. Następnie kontaktujesz się z nami, umawiasz termin montażu, a my realizujemy dalsze czynności techniczne i pomagamy przejść przez kolejne etapy obsługi.</p></div></section><section class=\"section section-dark\"><div class=\"container contact-band\"><div><h2>Skontaktuj się z nami</h2><p>Umów montaż blokady alkoholowej, zapytaj o formalności albo przejdź do procedury dzierżawy.</p></div>\n<div class=\"contact-list\">\n<div><strong>Bosch Car Service<br/>MWM Carmaster</strong></div>\n<div>ul. Krakowska 161, 25-705 Kielce</div>\n<div><a href=\"tel:+48605101100\">+48 605 101 100</a></div>\n<div><a href=\"tel:+48413452435\">+48 41 345 24 35</a></div>\n<div><a class=\"js-email\" data-domain=\"bosch-service.pl\" data-mail-link=\"true\" data-user=\"carmaster\" href=\"#\">carmaster [at] bosch-service.pl</a></div>\n<div>Poniedziałek–Piątek: 8:00–17:00</div>\n</div>\n</div></section>";
---
<BaseLayout title={title} description={description} currentPath={currentPath}>
  <Fragment set:html={pageHtml} />
</BaseLayout>
