---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Wiosenny serwis klimatyzacji w Kielcach";
const description = "Wiosenny serwis klimatyzacji w MWM Carmaster Bosch Car Service Kielce.";
const currentPath = "/oferta-bosch-wiosenny-serwis-klimatyzacji.html";
const pageHtml = "<section class=\"hero compact\">\n<div class=\"hero-media\">\n<picture>\n<source media=\"(max-width: 767px)\" srcset=\"img/offers/oferta-bosch-wiosna-2025-mobile.jpg\"/>\n<img alt=\"Aktualna oferta Bosch Car Service\" src=\"img/offers/oferta-bosch-wiosna-2025.jpg\"/>\n</picture>\n</div>\n<div class=\"hero-overlay\"></div>\n<div class=\"container hero-inner\">\n<h1>Wiosenny serwis klimatyzacji w Kielcach</h1>\n<p class=\"lead\">Wiosna to dobry moment, aby sprawdzić stan klimatyzacji przed sezonem intensywnego użytkowania. Sprawny układ klimatyzacji wpływa nie tylko na komfort jazdy latem, ale także na jakość powietrza w kabinie i wygodę codziennego użytkowania samochodu przez cały rok.</p>\n<div class=\"hero-actions\"><a class=\"btn btn-primary\" href=\"kontakt.html\">Umów serwis klimatyzacji</a></div>\n</div>\n</section>\n<section class=\"section\"><div class=\"container copy-block\"><h2>Dlaczego warto wykonać serwis klimatyzacji właśnie wiosną</h2><p>Po okresie zimowym warto sprawdzić sprawność i wydajność układu klimatyzacji, zanim zacznie pracować z pełnym obciążeniem w cieplejszych miesiącach. Regularna obsługa pomaga utrzymać prawidłowe działanie układu, poprawia komfort podróżowania i pozwala wcześniej wychwycić ewentualne nieprawidłowości.</p></div></section>\n<section class=\"section section-alt\">\n<div class=\"container split reverse\">\n<div class=\"split-media\"><img alt=\"Serwis klimatyzacji\" src=\"img/services/serwis-klimatyzacji-bosch-mwm.jpg\"/></div>\n<div class=\"split-copy\">\n<h2>Klimatyzacja to nie tylko chłodzenie</h2>\n<p>Klimatyzacja samochodowa wpływa na warunki panujące we wnętrzu pojazdu przez cały rok. Przy krótkich i długich trasach warto zadbać o czyste powietrze w kabinie, a regularna obsługa układu wentylacji i klimatyzacji pomaga utrzymać jego sprawność oraz komfort codziennej jazdy.</p>\n</div>\n</div>\n</section>\n<section class=\"section\"><div class=\"container copy-block\"><h2>Co obejmuje wiosenny serwis klimatyzacji</h2><p>W ramach wiosennego serwisu klimatyzacji wykonujemy kontrolę sprawności i wydajności instalacji klimatyzacyjnej, kontrolę elektroniki odpowiadającej za pracę układu oraz kontrolę szczelności. Jeżeli jest to potrzebne, uzupełniamy czynnik chłodniczy.</p></div></section><section class=\"section section-dark\"><div class=\"container contact-band\"><div><h2>Skontaktuj się z nami</h2><p>Umów serwis klimatyzacji, zadzwoń i zapytaj o termin albo skontaktuj się z serwisem.</p></div>\n<div class=\"contact-list\">\n<div><strong>Bosch Car Service<br/>MWM Carmaster</strong></div>\n<div>ul. Krakowska 161, 25-705 Kielce</div>\n<div><a href=\"tel:+48605101100\">+48 605 101 100</a></div>\n<div><a href=\"tel:+48413452435\">+48 41 345 24 35</a></div>\n<div><a class=\"js-email\" data-domain=\"bosch-service.pl\" data-mail-link=\"true\" data-user=\"carmaster\" href=\"#\">carmaster [at] bosch-service.pl</a></div>\n<div>Poniedziałek–Piątek: 8:00–17:00</div>\n</div>\n</div></section>";
---
<BaseLayout title={title} description={description} currentPath={currentPath}>
  <Fragment set:html={pageHtml} />
</BaseLayout>
